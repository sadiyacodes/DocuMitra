# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...        # Anthropic API key (https://console.anthropic.com)
SUPABASE_URL=https://<project>.supabase.co   # Project URL from Supabase dashboard → Settings → API
SUPABASE_KEY=eyJ...                 # anon/service_role key from the same page

# ── Optional ──────────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434   # Ollama server URL (LLM fallback)
DEMO_MODE=false                     # Set true to serve cached responses (run scripts/cache_demo.py first)
